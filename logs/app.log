section{Education}\n  \\resumeSubHeadingListStart\n    \\resumeSubheading\n      {Syracuse University}{Syracuse, NY}\n      {Master of Science in Computer Science}{Jan 2024 -- Dec 2025}\n    \\resumeSubheading\n      {DIT University}{Dehradun, India}\n      {Bachelor of Technology in Computer Science and Engineering}{Aug 2016 -- May 2020}\n  \\resumeSubHeadingListEnd\n\n\n%-----------EXPERIENCE-----------\n\\section{Experience}\n  \\resumeSubHeadingListStart\n\n\\resumeSubheading{\\textbf{Deloitte} $|$ \\emph{Senior Software Engineer}}{Feb 2021 -- Jan 2024}{React, Next.js, Redux, TypeScript, Node.js, AWS, D3.js, Three.js}{Bangalore, India}\n  \\resumeItemListStart\n    \\resumeItem{Developed and implemented responsive dashboards and fragments for Deloitte Insights using React, Next.js, and Redux, resulting in a 35\\% increase in user engagement and improved data visualization.}\n    \\resumeItem{Leveraged D3.js to create interactive charts and graphs for real-time data exploration, reducing decision-making time by 25\\% and enhancing data accuracy.}\n    \\resumeItem{Utilized Three.js to build 3D data visualizations, improving user experience and data accuracy by 20\\%, showcasing expertise in creating engaging and informative data presentations.}\n    \\resumeItem{Spearheaded cross-functional collaboration to independently design, deploy, and maintain 3 new systems, increasing team efficiency and impacting over 15 departments across the organization; consistently exceeding expectations and demonstrating strong leadership skills.}\n  \\resumeItemListEnd\n\n\\resumeSubheading{\\textbf{ToTheNew Pvt. Ltd.} $|$ \\emph{Software Engineer}}{Feb 2020 -- Mar 2021}{Angular 4+, Node.js, RxJS, MongoDB, Express}{Noida, India}\n  \\resumeItemListStart\n    \\resumeItem{Developed front-end solutions, including a COVID-19 dashboard and e-commerce platforms, using Angular 4+, RxJS, and REST APIs, improving client satisfaction for PWC and showcasing adaptability to diverse project needs.}\n    \\resumeItem{Architected and implemented the TCH channel studying portal using Angular 4+, REST APIs, and RxJS, enhancing the user learning experience and demonstrating proficiency in building scalable and user-friendly applications.}\n    \\resumeItem{Implemented RxJS to optimize asynchronous operations, reducing loading times by 50\\% across key application features, significantly improving customer satisfaction and boosting user retention rates by 15\\%; consistently exceeding expectations in performance optimization.}\n  \\resumeItemListEnd\n\n\\resumeSubheading{\\textbf{Smart Joules Pvt. Ltd.} $|$ \\emph{Joule Fellow}}{Sept 2018 -- Dec 2019}{Angular, TypeScript, RxJS, D3.js}{Dehradun, India}\n  \\resumeItemListStart\n    \\resumeItem{Built various applications, including D3 dashboards and multi-select autocomplete components, within the Smart Joules track system, showcasing a strong understanding of front-end development and user interface design.}\n    \\resumeItem{Developed and released an open-source NPM module for multi-select autocomplete, demonstrating initiative, collaboration, and a commitment to best practices; increased community contributions by 40\\%.}\n    \\resumeItem{Utilized Angular and RxJS to build responsive and functional D3 dashboards, enhancing the overall user experience and demonstrating proficiency in data visualization.}\n  \\resumeItemListEnd\n\n  \\resumeSubHeadingListEnd\n\n\n%-----------PROJECTS-----------\n\\section{Projects}\n    \\resumeSubHeadingListStart\n\n\\resumeProjectHeading{\\textbf{ScanFeast Mobile Web App} $|$ \\emph{React, Redux, D3.js, Firebase}}{Aug 2024 -- Present}\n  \\resumeItemListStart\n    \\resumeItem{Developed a React and Redux-powered restaurant app enabling seamless order placement via QR code scanning; improved order processing efficiency by 20\\%, demonstrating proficiency in building efficient and scalable applications.}\n    \\resumeItem{Integrated Firebase for backend operations, optimizing data storage and retrieval, and improving data retrieval speed by 30\\%, showcasing expertise in building reliable and efficient backend systems.}\n    \\resumeItem{Created interactive charts and graphs using D3.js for the restaurant dashboard, providing valuable insights for efficient order management and demonstrating the ability to create data-driven solutions.}\n  \\resumeItemListEnd\n\n\\resumeProjectHeading{\\textbf{MedConnect Mobile Web App} $|$ \\emph{React, Redux, Node.js, MongoDB, AWS, TypeScript}}{Sept 2024 -- Present}\n  \\resumeItemListStart\n    \\resumeItem{Engineered a full-stack mobile web application with Node.js for backend REST API services and React for frontend interactions, successfully integrating real-time data updates for over 500 weekly active users.}\n    \\resumeItem{Implemented JWT authentication for secure data retrieval, enhancing security protocols by 40\\%, demonstrating a strong understanding of security best practices.}\n    \\resumeItem{Developed a search interface using Algolia, reducing search times by 25\\%, enhancing user experience and showcasing expertise in building user-friendly and efficient applications.}\n  \\resumeItemListEnd\n\n    \\resumeSubHeadingListEnd\n\n\n%-----------TECHNICAL SKILLS-----------\n\\section{Technical Skills}\n \\begin{itemize}[leftmargin=0.15in, itemsep=1pt, topsep=2pt, parsep=0pt, label={}]\n\n    \\item \\small \\textbf{Skills:} React, Next.js, Redux, RxJS, Node.js, TypeScript, JavaScript, HTML/CSS, D3.js, Angular, Kotlin, Ruby, SQL, AWS, API Design, Microservices, Data Structures and Algorithms, System Design, Jest, GraphQL.\n    \\item \\small \\textbf{Tools:} Git, Firebase, Docker, AWS, MongoDB, Algolia, Selenium automation.\n\n \\end{itemize}\n\n\n%-------------------------------------------\n\\end{document}\n', 'work_model': 'Remote', 'last_attempted_at': datetime.datetime(2025, 5, 8, 22, 16, 51, 612000)}. Problematic raw user_profile (first 200 chars): {'full_name': 'Bhupesh Chikara', '